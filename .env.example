# Domain Configuration
DOMAIN=auto.palmwavestays.com
BASE_DOMAIN=palmwavestays.com
SSL_CERT=/etc/nginx/ssl/fullchain.pem
SSL_KEY=/etc/nginx/ssl/privkey.pem

# Timezone
TZ=Asia/Dhaka

# PostgreSQL Configuration
POSTGRES_USER=n8n
POSTGRES_PASSWORD=your-secure-postgres-password-here
POSTGRES_DB=n8n
SCHEMA_DB=auto_pws
ADMIN_PWS_DB=admin_pws
AUTO_PWS_DB=auto_pws
# Local-only: host port used by docker-compose.local.yml
POSTGRES_HOST_PORT=5432

# Workers service
WORKER_DB_NAME=auto_pws
WORKER_DEBUG_WORKER=
WORKER_DISABLE_MAINTENANCE=0
WORKERS_DEBUG_PORT=5678
OWNERREZ_BEARER_TOKEN=
OWNERREZ_API_BASE_URL=https://api.ownerrez.com/v2
# Path must be readable inside the workers container when set
OWNERREZ_CA_BUNDLE=
WHEELHOUSE_RM_API_KEY=
# Accepted local aliases for tooling/bootstrap scripts:
# - WHEELHOUSE_INTEGRATION_KEY
# - WHEELHOUSE_ACCESS_KEY
# - WHEELHOUSE_API_KEY
# - WHEELHOUSE_USER_ACCESS_TOKEN
# - WHEELHOUSE_USER_API_KEY

# FastAPI Password Safe Admin Configuration
# Generate with: openssl rand -hex 32
SECRET_KEY=replace-with-jwt-secret
SESSION_SECRET_KEY=replace-with-session-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
ACCESS_TOKEN_REMEMBER_DAYS=7

# SQL Secrets Module Encryption Key
# Used by DB session setting: app.secrets_key
SECRETS_ENCRYPTION_KEY=replace-with-secrets-encryption-key
