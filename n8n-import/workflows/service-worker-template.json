      "parameters": {
        "jsCode": "// Get the input data (items array from n8n)\nconst items = $input.all();  // This will be the array of items passed to the code node\n\n// Iterate over each item in the input data\nitems.forEach(item => {\n  // Graceful shutdown file check (optional)\n  let shutdownRequested = false;\n  if (String(item.json.metadata.worker_gracefull_shutdown).toLowerCase() === 'true' || item.json.metadata.worker_gracefull_shutdown === true) {\n    try {\n      const fs = require('fs');\n      shutdownRequested = fs.existsSync(`/tmp/worker_shutdown_${item.json.metadata.worker_id}`);\n    } catch (e) {\n      // ignore\n    }\n  }\n\n  // Only set shutdown_requested if the condition is true\n  if (shutdownRequested) {\n    item.json.metadata.shutdown_requested = true;\n  }\n});\n\n// Return the updated items\nreturn items;\n"
      },
