    {
      "parameters": {
        "jsCode": "// Get the input data (items array from n8n)\nconst items = $input.all();  // This will be the array of items passed to the code node\n\n// Get the current time (in milliseconds)\nconst currentTime = Date.now();\n\n// Iterate over each item in the input data\nitems.forEach(item => {\n  const metadata = item.json.metadata;\n\n  // Ensure necessary fields are available\n  if (metadata && metadata.heartbeat_interval && metadata.last_seen_at) {\n    // Convert heartbeat_interval from seconds to milliseconds\n    const heartbeatIntervalMs = metadata.heartbeat_interval.seconds * 1000;\n\n    // Convert last_seen_at to a timestamp\n    const lastSeenAtMs = new Date(metadata.last_seen_at).getTime();\n\n    // Calculate the time difference in milliseconds\n    const timeDiffMs = currentTime - lastSeenAtMs;\n\n    // If the time difference exceeds the heartbeat interval, set heartbeat_needed to true\n    if (timeDiffMs >= heartbeatIntervalMs) {\n      item.json.metadata.heartbeat_needed = true;\n    } else {\n      item.json.metadata.heartbeat_needed = false;\n    }\n  }\n});\n\n// Return the updated items\nreturn items;\n"
      },
