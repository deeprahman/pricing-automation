    {
      "parameters": {
        "jsCode": "// Get the input data (items array from n8n)\nconst items = $input.all();  // This will be the array of items passed to the code node\n\n// Iterate over each item in the input data\nitems.forEach(item => {\n  // Check if shutdown_requested is true\n  if (item.json.metadata.shutdown_requested === true) {\n    console.log(\"Shutdown Requested\");\n    // Check if graceful shutdown is enabled\n    if (item.json.metadata.worker_gracefull_shutdown) {\n      try {\n        console.log(\"Graceful shoutdown\");\n        const fs = require('fs');\n        const shutdownFile = '/tmp/worker_shutdown_' + item.json.metadata.worker_id;\n        console.log(shutdownFile);\n        // If the shutdown signal file exists, clear it\n        if (fs.existsSync(shutdownFile)) {\n          fs.unlinkSync(shutdownFile);\n          console.log('✓ Shutdown signal file cleared');\n          \n          // Optionally, set shutdown_requested to false or another value if needed after clearing the file\n          // For now, we leave it as true, assuming once it is requested, it remains true\n        }\n      } catch (e) {\n        console.error('Failed to clear shutdown signal:', e.message);\n      }\n    }\n  }\n});\n\n// Return the updated items\nreturn items;\n"
      },
