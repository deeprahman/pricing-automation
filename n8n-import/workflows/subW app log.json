    {
      "parameters": {
        "jsCode": "// ── Build Slack / Email alert for FATAL logs ────────────────\nconst log = $input.first().json;\n\nconst alertPayload = {\n  title:    '🚨 FATAL LOG ALERT',\n  text:     `*${log.source}* reported a FATAL error`,\n  fields: [\n    { label: 'Message',    value: log.message },\n    { label: 'Workflow',   value: log.workflow_name ?? 'N/A' },\n    { label: 'Execution',  value: log.execution_id  ?? 'N/A' },\n    { label: 'Error Code', value: log.error_code    ?? 'N/A' },\n    { label: 'User',       value: log.user_id       ?? 'N/A' },\n    { label: 'Stack',      value: (log.error_stack ?? '').substring(0, 500) }\n  ],\n  timestamp: new Date().toISOString()\n};\n\nreturn [{\n  json: {\n    ...log,\n    alert_payload: alertPayload\n  }\n}];"
      },
      "id": "10ab2d3a-4169-4969-84f3-e9283e14bbd8",
      "name": "📣 Build Alert Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -608,
        -16
      ],
      "onError": "continueErrorOutput",
      "notes": "Runs only for FATAL level. Extend this node to call Slack, PagerDuty, email etc."
    },
    {
      "parameters": {
        "jsCode": "// Return success payload to the parent workflow\nconst inserted = $input.first().json;\n\nreturn [{\n  json: {\n    success: true,\n    log_id: inserted.id,\n    level: inserted.level,\n    saved_at: inserted.created_at\n  }\n}];"
      },
      "id": "8a91f6cf-fa79-4383-b57c-0e0310f08b76",
      "name": "✅ Return Success",
      "type": "n8n-nodes-base.code",
