      "name": "🧩 Triggered by Workflow",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1,
      "position": [
        -1504,
        560
      ],
      "notes": "Call this workflow from another workflow via Execute Workflow node. Input JSON: { level, message, source, metadata, error_code, error_stack, user_id, request_id, ip_address }"
    },
    {
      "parameters": {
        "jsCode": "// ── Validate & Normalize Incoming Log Payload ───────────────\nconst VALID_LEVELS = ['DEBUG', 'INFO', 'WARN', 'ERROR', 'FATAL'];\n\nconst input = $input.first().json;\nconst body = input.body ?? input;\nconst headers = input.headers ?? {};\n\n// ── Required field check ─────────────────────────────────────\nif (!body.message || typeof body.message !== 'string' || body.message.trim() === '') {\n  throw new Error('Validation failed: `message` is required and must be a non-empty string.');\n}\n\n// ── Normalize level ──────────────────────────────────────────\nconst rawLevel = (body.level ?? 'INFO').toString().toUpperCase().trim();\nconst level = VALID_LEVELS.includes(rawLevel) ? rawLevel : 'INFO';\n\n// ── Normalize client IP (first forwarded hop only) ───────────\nconst forwardedHeader =\n  headers['x-forwarded-for']\n  ?? headers['X-Forwarded-For']\n  ?? headers['x-real-ip']\n  ?? headers['X-Real-IP']\n  ?? null;\n\nconst forwardedValue = Array.isArray(forwardedHeader) ? forwardedHeader[0] : forwardedHeader;\nlet ipAddress = null;\n\nif (typeof forwardedValue === 'string' && forwardedValue.trim() !== '') {\n  const firstHop = forwardedValue.split(',')[0].trim();\n  const ipv4WithPort = firstHop.match(/^(\\d{1,3}(?:\\.\\d{1,3}){3}):\\d+$/);\n  const bracketedIpv6 = firstHop.match(/^\\[([0-9a-fA-F:]+)\\](?::\\d+)?$/);\n\n  if (ipv4WithPort) {\n    ipAddress = ipv4WithPort[1];\n  } else if (bracketedIpv6) {\n    ipAddress = bracketedIpv6[1];\n  } else {\n    ipAddress = firstHop;\n  }\n}\n\n// ── Extract execution context injected by n8n ────────────────\nconst execId   = $execution?.id   ?? null;\nconst wfId     = $workflow?.id    ?? null;\nconst wfName   = $workflow?.name  ?? null;\n\n// ── Build clean log entry ────────────────────────────────────\nconst logEntry = {\n  level,\n  message:       body.message.trim().substring(0, 5000),\n  source:        (body.source ?? 'n8n').toString().substring(0, 100),\n  workflow_id:   wfId,\n  workflow_name: wfName,\n  execution_id:  execId,\n  metadata:      (body.metadata && typeof body.metadata === 'object' && !Array.isArray(body.metadata)) ? body.metadata : {},\n  error_code:    body.error_code  ?? null,\n  error_stack:   body.error_stack ?? null,\n  request_id:    body.request_id  ?? null,\n  user_id:       body.user_id     ?? null,\n  ip_address:    ipAddress\n};\n\nreturn [{ json: logEntry }];"
      },
