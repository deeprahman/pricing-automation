      ]
    },
    {
      "parameters": {
        "jsCode": "// ── Global error handler for workflow error output ───────────\nconst payload = $input.first().json ?? {};\nconst nestedError = payload.error ?? payload.execution?.error ?? null;\n\nconst errorMessage =\n  nestedError?.message\n  ?? payload.message\n  ?? (typeof nestedError === 'string' ? nestedError : null)\n  ?? 'Unknown error occurred';\n\nconsole.error('[Logger Workflow Error]', errorMessage);\n\nreturn [{\n  json: {\n    success: false,\n    error: errorMessage,\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
