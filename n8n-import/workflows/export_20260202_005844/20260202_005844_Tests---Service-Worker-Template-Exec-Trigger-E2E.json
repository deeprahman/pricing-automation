                "position": [
                    608,
                    208
                ]
            },
            {
                "parameters": {
                    "jsCode": "const runId = new Date().toISOString();\nconst runIdSafe = runId.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');\nconst queueName = `test_queue_${runIdSafe.slice(0, 24)}`;\nconst workerId = `test_worker_${runIdSafe.slice(0, 24)}`;\nconst workerName = `Test Worker ${runId}`;\n\nconst context = {\n  run_id: runId,\n  worker_workflow_id: 'gAaVz2ymEGWty1PfRrhY2',\n  queue_name: queueName,\n  worker_id: workerId,\n  worker_name: workerName,\n  api_key: null,\n  task_uuid_a: null,\n  task_uuid_long: null,\n  task_uuid_b: null,\n  results: []\n};\n\nreturn [{ json: { context } }];"
                },
                "id": "75f1223d-e4e3-40c2-8937-672aa498f96e",
                "name": "Init Test Context",
                "type": "n8n-nodes-base.code",
                "typeVersion": 2,
                "position": [
                    816,
                    208
                ]
            },
            {
                "parameters": {
                    "operation": "executeQuery",
                    "query": "SELECT create_queue('{{ $json.context.queue_name }}', '{{ 'Test queue for run ' + $json.context.run_id }}') AS create_queue;",
                    "options": {}
                },
                "id": "8f22280f-a8ec-4b27-af0d-b1b94eb35681",
                "name": "Create Queue",
                "type": "n8n-nodes-base.postgres",
                "typeVersion": 2.5,
