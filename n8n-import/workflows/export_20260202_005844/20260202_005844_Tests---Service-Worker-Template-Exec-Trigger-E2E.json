                    1008,
                    208
                ],
                "credentials": {
                    "postgres": {
                        "id": "DaS7mZvyZ9LN6V5S",
                        "name": "Postgress-n8n-db"
                    }
                },
                "continueOnFail": true
            },
            {
                "parameters": {
                    "jsCode": "const prev = $items('Init Test Context')[0].json.context;\nconst result = $input.all()[0]?.json ?? {};\nconst ok = result.create_queue === true || result.create_queue === 't' || result.create_queue === 1;\nconst error = result.error || result.message || null;\n\nconst testResult = {\n  name: 'create_queue',\n  success: ok && !error,\n  expected: 'create_queue returns true',\n  actual: result,\n  error\n};\n\nconst context = { ...prev, results: [...prev.results, testResult] };\n\nreturn [{ json: { context } }];"
                },
                "id": "f705e909-0a17-4efe-b054-ba327b8a6a14",
