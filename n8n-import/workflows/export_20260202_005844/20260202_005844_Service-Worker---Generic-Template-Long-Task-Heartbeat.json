            {
                "parameters": {
                    "content": "## Template Customization\n\n1) Update **Worker Config** values (serviceId, apiKey, intervals).\n2) Replace task_example_* handlers with your task implementations.\n3) Add/remove routes in **Route by Task Name**.\n\nPostgres functions assumed:\n- send_heartbeat(service_id, api_key)\n- dequeue_task(service_id, api_key)\n- complete_task(task_id, api_key, result_json)\n- fail_task(task_id, api_key, error_msg)",
                    "height": 350,
                    "width": 420,
                    "color": 4
                },
                "id": "16a7b00f-bfe7-4ea0-8e7b-de6ffcffdd1c",
                "name": "Template Notes",
                "type": "n8n-nodes-base.stickyNote",
                "typeVersion": 1,
                "position": [
                    -2176,
                    272
                ]
            },
            {
                "parameters": {
                    "content": "## Task Routing\n\n**Output 0:** task_example_a\n**Output 1:** task_example_b\n**Output 2:** task_long_batch\n**Output 3 (fallback):** Unknown task -> fail_task",
                    "height": 240,
                    "width": 360,
                    "color": 5
                },
                "id": "e7d3c74e-9412-41ad-8a68-c6cd272186a6",
                "name": "Routing",
                "type": "n8n-nodes-base.stickyNote",
                "typeVersion": 1,
                "position": [
                    0,
                    16
                ]
            },
            {
                "parameters": {
                    "jsCode": "const item = $input.item;\nconst taskData = item.json.taskData || {};\nconst units = Array.isArray(taskData.units)\n  ? taskData.units\n  : Array.from({ length: taskData.totalUnits || 0 }, (_, i) => ({ index: i }));\nconst batchSize = taskData.batchSize || 10;\n\nif (!units.length) {\n  // No units provided; return a single placeholder item\n  return [{ json: { ...item.json, unitIndex: 0, totalUnits: 0, batchSize } }];\n}\n\nreturn units.map((unit, idx) => ({\n  json: {\n    ...item.json,\n    unit,\n    unitIndex: idx,\n    totalUnits: units.length,\n    batchSize\n  }\n}));\n"
                },
                "id": "c1b4a681-2a37-47b2-859d-aafe86ec0410",
                "name": "Prepare Units",
                "type": "n8n-nodes-base.code",
                "typeVersion": 2,
                "position": [
                    848,
                    736
                ]
            },
            {
                "parameters": {
                    "batchSize": "={{ $json.batchSize || 10 }}",
                    "options": {}
                },
                "id": "c7a6104a-6128-4811-ab55-a291d04c7ada",
                "name": "Batch Units (n)",
                "type": "n8n-nodes-base.splitInBatches",
                "typeVersion": 1,
                "position": [
                    1072,
                    736
                ]
            },
            {
                "parameters": {
                    "jsCode": "const items = $input.all();\nconst started = Date.now();\n// TODO: Process each unit in this batch\n// Example: call an API, transform data, write to DB, etc.\nconst durationMs = Date.now() - started;\nfor (const item of items) {\n  item.json.batchDurationMs = durationMs;\n}\nreturn items;\n"
                },
                "id": "580b57bc-a088-4f5c-aa3b-40f21319e171",
                "name": "Process Batch (n units)",
                "type": "n8n-nodes-base.code",
                "typeVersion": 2,
                "position": [
                    1296,
                    592
                ]
            },
            {
                "parameters": {
                    "jsCode": "const items = $input.all();\nconst now = Date.now();\nfor (const item of items) {\n  const taskData = item.json.taskData || {};\n  const leaseExpiresAt = taskData.leaseExpiresAt || taskData.lease_expires_at || item.json.leaseExpiresAt || null;\n  const remainingMs = leaseExpiresAt ? new Date(leaseExpiresAt).getTime() - now : null;\n  const batchMs = item.json.batchDurationMs || 0;\n  const bufferMs = taskData.leaseBufferMs || Math.max(5000, batchMs);\n  const thresholdMs = batchMs + bufferMs;\n  item.json.remainingLeaseMs = remainingMs;\n  item.json.heartbeatThresholdMs = thresholdMs;\n  item.json.shouldExtendLease = remainingMs === null ? true : remainingMs < thresholdMs;\n  item.json.extendByInterval = taskData.extendByInterval || '5 minutes';\n}\nreturn items;\n"
                },
                "id": "018d0d68-3097-4934-bd8e-a797ca94d48e",
                "name": "Lease Check (threshold)",
                "type": "n8n-nodes-base.code",
                "typeVersion": 2,
                "position": [
                    1520,
                    592
                ]
            },
            {
                "parameters": {
                    "conditions": {
                        "options": {
                            "caseSensitive": true,
                            "leftValue": "",
                            "typeValidation": "strict"
                        },
                        "conditions": [
                            {
                                "id": "extend-lease",
                                "leftValue": "={{ $json.shouldExtendLease }}",
                                "rightValue": "true",
                                "operator": {
                                    "type": "boolean",
                                    "operation": "true"
                                }
                            }
                        ],
                        "combinator": "and"
                    },
                    "options": {}
                },
                "id": "769cc92b-0360-4939-ac9d-485c5be9bf57",
