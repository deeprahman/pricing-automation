    {
      "parameters": {
        "jsCode": "// Log shutdown and cleanup\nconst state = $getWorkflowStaticData('global');\nconst item = $input.item.json;\n\nconst successRate = state.tasksProcessed > 0 \n  ? ((state.tasksProcessed - state.tasksFailed) / state.tasksProcessed * 100).toFixed(2) + '%'\n  : 'N/A';\n\nconsole.log('=================================');\nconsole.log('WORKER SHUTTING DOWN');\nconsole.log('=================================');\nconsole.log('Reason:', item.shutdownReason);\nconsole.log('Uptime:', Math.floor(item.runDuration / 1000) + 's');\nconsole.log('Tasks Processed:', state.tasksProcessed);\nconsole.log('Tasks Failed:', state.tasksFailed);\nconsole.log('Success Rate:', successRate);\nconsole.log('Current Load:', item.currentLoad);\nconsole.log('=================================');\n\n// Clear shutdown signal file\nif (item.enableGracefulShutdown) {\n  try {\n    const fs = require('fs');\n    const shutdownFile = '/tmp/worker_shutdown_' + item.serviceId;\n    if (fs.existsSync(shutdownFile)) {\n      fs.unlinkSync(shutdownFile);\n      console.log('✓ Shutdown signal file cleared');\n    }\n  } catch (e) {\n    console.error('Failed to clear shutdown signal:', e.message);\n  }\n}\n\n// Reset state for next run\nstate.initialized = false;\nstate.workerRegistered = false;\n\nconsole.log('Worker shutdown complete.');\n\nreturn [];"
      },
