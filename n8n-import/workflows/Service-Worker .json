    {
      "parameters": {
        "jsCode": "const state = $('load worker state').item.json;\nconst item = $input.item.json;\n\n// Set current task ID\nstate.currentTaskId = item.taskId;\nstate.taskStartTime = Date.now();\n\n// Reset consecutive errors on successful task acquisition\nstate.consecutiveErrors = 0;\nstate.errorBackoff = false;\n\nconsole.log('▶ Processing task:', {\n  taskId: item.taskId,\n  taskUuid: item.taskUuid,\n  taskName: item.taskName,\n  queue: item.queueName,\n  attempt: item.attemptNumber + '/' + item.maxAttempts\n});\n\nreturn $input.all();"
      },
