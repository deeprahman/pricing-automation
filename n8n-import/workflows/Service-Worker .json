    {
      "parameters": {
        "operation": "executeQuery",
        "query": "-- Validate queues exist and worker has access\nSELECT \n  array_agg(qr.queue_name) as valid_queues,\n  array_agg(qr.queue_name) FILTER (WHERE qr.is_active = FALSE) as inactive_queues,\n  COUNT(qr.queue_name) as found_count\nFROM unnest(ARRAY[{{ $json.queueNames.map(q => \"'\" + q + \"'\").join(',') }}]) AS requested(queue_name)\nLEFT JOIN queue_registry qr ON qr.queue_name = requested.queue_name;",
        "options": {}
