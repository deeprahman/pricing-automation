    {
      "parameters": {
        "jsCode": "const config = $input.item.json;\n\n// Use \"now\" as startTime unless caller provided one.\n// If you want startTime to persist across the workflow, pass it forward in JSON.\nconst now = Date.now();\nconst startTime = typeof config.startTime === 'number' ? config.startTime : now;\n\n// If you want these to persist across the workflow, pass them forward too.\n// Otherwise they default each run.\nconst lastHeartbeat = typeof config.lastHeartbeat === 'number' ? config.lastHeartbeat : 0;\nconst currentTaskId = config.currentTaskId ?? null;\nconst errorBackoff = typeof config.errorBackoff === 'boolean' ? config.errorBackoff : false;\nconst backoffUntil = typeof config.backoffUntil === 'number' ? config.backoffUntil : 0;\nconst consecutiveErrors = typeof config.consecutiveErrors === 'number' ? config.consecutiveErrors : 0;\nconst tasksProcessed = typeof config.tasksProcessed === 'number' ? config.tasksProcessed : 0;\nconst tasksFailed = typeof config.tasksFailed === 'number' ? config.tasksFailed : 0;\nconst batchHistory = Array.isArray(config.batchHistory) ? config.batchHistory : [];\n\n// Current load can only be derived from input (or an external DB query).\nconst currentLoad = currentTaskId ? 1 : 0;\n\n// Shutdown checks\nconst runDuration = now - startTime;\nconst shouldShutdownByTime = runDuration > Number(config.maxRuntimeMs ?? 0);\n\n// Graceful shutdown file check (optional)\nlet shutdownRequested = false;\nif (String(config.enableGracefulShutdown).toLowerCase() === 'true' || config.enableGracefulShutdown === true) {\n  try {\n    const fs = require('fs');\n    shutdownRequested = fs.existsSync(`/tmp/worker_shutdown_${config.serviceId}`);\n  } catch (e) {\n    // ignore\n  }\n}\n\nconst shouldShutdown = shouldShutdownByTime || shutdownRequested;\n\nreturn [\n  {\n    json: {\n      ...config,\n\n      // state values (carried forward in JSON)\n      startTime,\n      lastHeartbeat,\n      currentTaskId,\n      currentLoad,\n      errorBackoff,\n      backoffUntil,\n      consecutiveErrors,\n      tasksProcessed,\n      tasksFailed,\n      batchHistory,\n\n      // derived values\n      runDuration,\n      shouldShutdown,\n      shutdownReason: shouldShutdownByTime\n        ? 'max_runtime'\n        : shutdownRequested\n          ? 'graceful_shutdown'\n          : null,\n    },\n  },\n];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
