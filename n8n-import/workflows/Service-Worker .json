    {
      "parameters": {
        "jsCode": "// Enhanced queue validation failure handling\nconst state = $getWorkflowStaticData('global');\nconst item = $input.item.json;\nconst config = $('Worker Config').item.json;\n\nconst requestedQueues = config.queueNames;\nconst inactiveQueues = item.inactive_queues || [];\nconst validQueues = (item.valid_queues || []).filter(q => q !== null);\nconst missingQueues = requestedQueues.filter(q => !validQueues.includes(q));\n\nconsole.error('=================================');\nconsole.error('QUEUE VALIDATION FAILED');\nconsole.error('=================================');\nconsole.error('Requested:', requestedQueues);\nconsole.error('Missing:', missingQueues);\nconsole.error('Inactive:', inactiveQueues);\nconsole.error('=================================');\n\n// Determine backoff strategy\nlet backoffMs;\n\nif (inactiveQueues.length > 0 && missingQueues.length === 0) {\n  // Queues exist but are inactive - shorter backoff\n  console.warn('Queues are temporarily inactive, will retry soon');\n  backoffMs = Math.min(30000, config.backoffBaseMs); // 30 seconds max\n} else if (missingQueues.length > 0) {\n  // Queues don't exist - longer backoff\n  console.error('Queues do not exist - check configuration');\n  backoffMs = config.backoffMaxMs; // Maximum backoff\n} else {\n  // Unknown error\n  backoffMs = config.backoffBaseMs * Math.pow(2, state.consecutiveErrors);\n}\n\nbackoffMs = Math.min(config.backoffMaxMs, backoffMs);\n\nstate.errorBackoff = true;\nstate.backoffUntil = Date.now() + backoffMs;\nstate.consecutiveErrors++;\n\nconsole.error('Entering backoff for', backoffMs, 'ms');\n\nreturn [];"
      },
