        "query": "SELECT * FROM register_worker(\n  '{{ $json.registrationData.workerId }}',\n  '{{ $json.registrationData.workerId }}',\n  {{ $json.registrationData.maxConcurrentTasks }},\n  '{{ $json.registrationData.heartbeatInterval }}'::INTERVAL,\n  '{{ JSON.stringify($json.registrationData.queueNames) }}'::JSONB\n);",
