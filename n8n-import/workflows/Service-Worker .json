    {
      "parameters": {
        "jsCode": "// Wait during backoff period\nconst state = $getWorkflowStaticData('global');\nconst waitMs = Math.max(1000, state.backoffUntil - Date.now());\n\nconsole.log('In error backoff, waiting:', {\n  waitMs: waitMs,\n  consecutiveErrors: state.consecutiveErrors,\n  backoffUntil: new Date(state.backoffUntil).toISOString()\n});\n\nawait new Promise(resolve => setTimeout(resolve, waitMs));\n\n// Clear backoff if time has passed\nif (Date.now() >= state.backoffUntil) {\n  console.log('Backoff period ended, resuming normal operation');\n  state.errorBackoff = false;\n}\n\nreturn [];"
      },
