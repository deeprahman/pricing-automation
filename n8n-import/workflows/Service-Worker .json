    {
      "parameters": {
        "jsCode": "const checkRegistrationItems = $items('check registration');\nconst registerWorkerItems = $items('register worker');\n\nconst apiKey = registerWorkerItems[0]?.json?.api_key;\nif (!apiKey) {\n  throw new Error('API key not found in register worker output');\n}\n\nreturn checkRegistrationItems.map((item) => {\n  // Destructure to remove 'needsRegistration' and 'registrationData'\n  const { needsRegistration, registrationData, ...rest } = item.json;\n\n  return {\n    json: {\n      ...rest,\n      api_key: apiKey,\n\n    },\n  };\n});\n;\n"
      },
