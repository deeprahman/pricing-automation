    {
      "parameters": {
        "jsCode": "const waitMs = $('Worker Config').item.json.pollWaitMs;\n\n// Optional: Log every 10th poll cycle to avoid spam\nconst state = $getWorkflowStaticData('global');\nstate.pollCount = (state.pollCount || 0) + 1;\n\nif (state.pollCount % 10 === 0) {\n  console.log('No tasks available (poll #' + state.pollCount + '), waiting', waitMs, 'ms');\n}\n\nawait new Promise(resolve => setTimeout(resolve, waitMs));\nreturn [];"
      },
