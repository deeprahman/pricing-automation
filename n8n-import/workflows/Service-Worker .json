    {
      "parameters": {
        "jsCode": "const input = $input.first().json.metadata; // Access the first item of the array\nconst config = input;\n\n\n// Check if the 'config' exists before proceeding\nif (!config) {\n  throw new Error('get_worker_metadata is missing or not properly structured');\n}\n\n// Check if the 'config' exists before proceeding\nif (!config) {\n  throw new Error('get_worker_metadata is missing or not properly structured');\n}\n\n// Treat null/undefined/empty string as \"no api key\"\nconst noApiKey =\n  config.api_key === null ||\n  config.api_key === undefined ||\n  (typeof config.api_key === 'string' && config.api_key.trim() === '');\n\n// Ensure that `queueNames` is an array\nconst queueNames = Array.isArray(config.queueNames) ? config.queueNames : (config.queueNames ? [config.queueNames] : []);\n\n// Condition to check if runDuration is greater than 3 minutes and currentLoad is 0\nconst isRunDurationGreaterThan3Minutes = config.runDuration > 180000; // 180000 ms = 3 minutes\nconst isCurrentLoadZero = config.currentLoad === 0;\n\n// If either no API key or the new condition applies, registration is needed\nif (noApiKey || (isRunDurationGreaterThan3Minutes && isCurrentLoadZero)) {\n  const registrationData = {\n    workerId: config.serviceId,\n    queueNames: queueNames, // Now using the properly formatted array\n    maxConcurrentTasks: Number(config.maxConcurrentTasks ?? 1),\n    heartbeatInterval: config.heartbeatInterval, // keep original form if you need it\n  };\n\n  return [\n    {\n      json: {\n        ...config,\n        needsRegistration: true,\n        registrationData,\n      },\n    },\n  ];\n}\n\n// Otherwise, skip registration\nreturn [\n  {\n    json: {\n      ...config,\n      needsRegistration: false,\n    },\n  },\n];"
      },
